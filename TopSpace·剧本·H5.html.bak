/* ===== 幕尾钩子 ===== */
function showHook(sceneId,tag,questions){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var h=document.createElement('div');h.className='act-hook';
    var html='<div class="act-hook-tag">'+tag+'</div><div class="act-hook-line"></div><div class="act-hook-text">';
    if(Array.isArray(questions)){
      questions.forEach(function(q,i){
        if(i>0)html+='<br>';
        // 用em包裹关键词
        html+=q.replace(/"([^"]+)"/g,'<em>"$1"</em>');
      });
    }else{
      html+=questions.replace(/"([^"]+)"/g,'<em>"$1"</em>');
    }
    html+='</div>';
    h.innerHTML=html;
    sc.appendChild(h);
    setTimeout(function(){h.classList.add('show');playTone(600,.1,'sine',.02);setTimeout(resolve,2200);},200);
  });
}

/* ===== 彩蛋幕：偷看部落总部 ===== */
function easterEgg(){
  return switchScene('sc-easter',1000).then(function(){
    return addNpc('sc-easter');
  }).then(function(){
    return addLine('噢','（压低声音）那边那个最大的星球，就是部落总部。');
  }).then(function(){
    return addLine(null,'为什么要偷偷的？',true);
  }).then(function(){
    return addLine('噢','因为……我也不知道能不能进。反正我昨天是翻进来的。');
  }).then(function(){
    return addLine('噢','就是……绕了一圈没找到门，就钻进来了。');
  }).then(function(){
    return addLine('噢','（两人扒在一颗小卫星后面）你看——红色的，是市场中心。');
  }).then(function(){
    return addLine('噢','他们管外面的人怎么知道我们。品牌站、广播站、情报局、推广局。');
  }).then(function(){
    return addLine(null,'听着像一支军队。',true);
  }).then(function(){
    return addLine('噢','哈哈哈！他们的武器不是刀枪，是故事和创意。');
  }).then(function(){
    return addLine('噢','那个蓝色的，是内容中心。市场中心负责让别人看到我们，他们负责让别人觉得"哇"。');
  }).then(function(){
    return addLine('噢','金色的，商务中心。他们找到那些"有东西但没人看到"的人，还跟外面组织联手。');
  }).then(function(){
    return addLine('噢','绿色的，产品中心。技术部、AI研究院——他们研究怎么帮创造者做得更好。');
  }).then(function(){
    return addLine('噢','紫色的，体验中心。如果产品中心管"能不能用"，他们管"好不好玩"。');
  }).then(function(){
    return addLine('噢','中间最大的，就是部落总部。里面只有两个人——后勤站和账房。');
  }).then(function(){
    return addLine(null,'后勤和算账？',true);
  }).then(function(){
    return addLine('噢','对。后勤管所有鸡毛蒜皮的事，账房管钱。创造者负责创造，总得有人盯着账本。');
  }).then(function(){
    return addLine('系统','我管你们。');
  }).then(function(){
    return addLine('噢','你！！怎么——');
  }).then(function(){
    return addLine('系统','我什么都会。我一直都在。');
  }).then(function(){
    return addLine('系统','你们两个，偷看得还开心吗？');
  }).then(function(){
    return addLine('噢','（小声）还、还行。');
  }).then(function(){
    return addLine('系统','行。那出来吧。');
  }).then(function(){
    return showHint('故事未完 · 觉醒才刚开始');
  });
}

/* ===== 启动 ===== */
var currentChapter = 0;
var started = false;

function runChapter(idx){
  if(idx >= chapters.length){
    // 全部结束，返回
    setProgress(100);
    setActTitle('【觉醒纪元 · 完】');
    return;
  }
  currentChapter = idx;
  setProgress(Math.round((idx+1)/chapters.length*100));
  // 切换到对应场景
  var sceneId = idx===0 ? 'sc-prologue' : 'sc-'+String(idx).padStart(2,'0');
  switchScene(sceneId,800).then(function(){
    return chapters[idx]();
  }).then(function(){
    // 等用户点击后进入下一章
  });
}

// 启动遮罩
var startOverlay = document.createElement('div');
startOverlay.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;z-index:999;background:rgba(0,0,0,.8);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;';
startOverlay.innerHTML='<div style="text-align:center;"><div style="font-size:24px;margin-bottom:12px;">🌌</div><div style="font-size:14px;color:rgba(232,180,76,.6);letter-spacing:3px;">拓圈宇宙 · 觉醒纪元</div><div style="font-size:11px;color:rgba(255,255,255,.2);margin-top:8px;letter-spacing:2px;">点击开始</div></div>';
startOverlay.addEventListener('click',function(){
  if(started)return;started=true;
  ensureAudio();
  startOverlay.style.transition='opacity .6s';
  startOverlay.style.opacity='0';
  setTimeout(function(){startOverlay.remove();runChapter(0);},600);
});
startOverlay.addEventListener('touchstart',function(){
  if(started)return;started=true;
  ensureAudio();
  startOverlay.style.transition='opacity .6s';
  startOverlay.style.opacity='0';
  setTimeout(function(){startOverlay.remove();runChapter(0);},600);
});
document.body.appendChild(startOverlay);
</script>
</body>
</html>
