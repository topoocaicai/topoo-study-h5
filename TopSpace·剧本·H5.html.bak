      btn.style.cssText='margin-top:24px;padding:16px 32px;border-radius:30px;background:rgba(232,180,76,.12);border:1px solid rgba(232,180,76,.3);color:var(--amber);font-size:14px;letter-spacing:3px;cursor:pointer;opacity:0;transition:all .8s;z-index:15;text-align:center;';
