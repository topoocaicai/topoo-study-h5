<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<title>TopSpace · 拓圈宇宙 · 觉醒纪元 v1.1</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --dark:#0B0F1E;--amber:#E8B44C;--amber-glow:rgba(232,180,76,.5);
  --fire:#D96B6B;--water:#4A9EB8;--wood:#A0B87A;--gold:#E8B44C;--earth:#9B7BBF;
}
html,body{width:100%;height:100%;overflow:hidden;background:#000;touch-action:none;}
body{
  font-family:-apple-system,"PingFang SC","Helvetica Neue",sans-serif;
  -webkit-font-smoothing:antialiased;color:#fff;
  -webkit-user-select:none;user-select:none;
}
#app{width:100vw;height:100vh;position:relative;overflow:hidden;background:#000;}
canvas#bgCanvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;}

/* ===== 星空 ===== */
.starfield{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--d,3s) ease-in-out infinite alternate;opacity:0;}
@keyframes twinkle{0%{opacity:.03;transform:scale(.5)}100%{opacity:var(--o,.6);transform:scale(1.1)}}

/* ===== 场景 ===== */
.scene{
  position:absolute;top:0;left:0;width:100%;height:100%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity 1.2s cubic-bezier(.23,1,.32,1);
  z-index:1;padding:20px;
}
.scene.active{opacity:1;pointer-events:auto;}

/* ===== 幕标题 ===== */
.act-title{
  position:fixed;top:env(safe-area-inset-top,20px);left:50%;transform:translateX(-50%);
  z-index:50;font-size:11px;color:rgba(255,255,255,.25);letter-spacing:3px;
  white-space:nowrap;opacity:0;transition:opacity .8s;
}
.act-title.show{opacity:1;}

/* ===== 进度条 ===== */
.progress-bar{
  position:fixed;bottom:0;left:0;width:100%;height:2px;z-index:100;
  background:rgba(255,255,255,.03);
}
.progress-fill{height:100%;width:0;background:linear-gradient(90deg,var(--amber),rgba(74,158,184,.5));transition:width 1s ease;}

/* ===== 打字机对话 ===== */
.dialogue-area{
  position:absolute;top:8%;left:50%;transform:translateX(-50%);
  width:88vw;max-width:420px;z-index:15;text-align:center;
  max-height:50vh;overflow-y:auto;
}
.dialogue-area::-webkit-scrollbar{width:1px;}
.dialogue-area::-webkit-scrollbar-thumb{background:rgba(232,180,76,.15);border-radius:1px;}

.dia-line{margin-bottom:16px;opacity:0;animation:lineIn .5s ease forwards;}
@keyframes lineIn{to{opacity:1;}}
.dia-label{
  font-size:9px;color:rgba(232,180,76,.35);
  letter-spacing:3px;margin-bottom:4px;
  font-family:"SF Mono","Menlo",monospace;
}
.dia-text{
  font-size:17px;color:var(--amber);letter-spacing:.8px;line-height:2;
  font-family:"SF Mono","Menlo",monospace;
  border-right:2px solid rgba(232,180,76,.6);
  animation:cursorBlink 1.2s step-end infinite;
  white-space:pre-wrap;word-break:break-all;
  display:inline;
}
.dia-text.done{border-right-color:transparent;animation:none;}
.dia-text.user{color:rgba(255,255,255,.85);}
@keyframes cursorBlink{0%,100%{border-right-color:rgba(232,180,76,.6)}50%{border-right-color:transparent}}

/* ===== 触摸提示 ===== */
.touch-hint{
  position:absolute;bottom:14%;left:50%;transform:translateX(-50%);
  text-align:center;z-index:21;pointer-events:none;
  opacity:0;transition:opacity 1s;
}
.touch-hint.show{opacity:1;}
.touch-hint-icon{
  width:44px;height:44px;margin:0 auto 8px;
  border:1px solid rgba(255,255,255,.1);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  animation:hintFloat 2.5s ease infinite;
}
@keyframes hintFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
.touch-hint-text{font-size:12px;color:rgba(255,255,255,.3);letter-spacing:2px;}

/* ===== 视觉元素 ===== */
/* 坠落金色粒子 */
.fall-particle{
  position:absolute;width:5px;height:5px;border-radius:50%;
  background:var(--amber);box-shadow:0 0 8px var(--amber-glow);
  opacity:0;z-index:10;
}

/* 星球 */
.visual-planet{
  position:absolute;bottom:-50px;left:50%;
  transform:translateX(-50%) scale(.15);
  width:200px;height:200px;
  background:radial-gradient(circle at 35% 35%,rgba(74,158,184,.3),rgba(11,15,30,.9) 70%);
  border-radius:50%;
  box-shadow:0 0 60px rgba(74,158,184,.15),inset 0 0 40px rgba(232,180,76,.05);
  opacity:0;transition:all 2.2s cubic-bezier(.23,1,.32,1);z-index:2;
}
.visual-planet.show{bottom:15%;opacity:1;transform:translateX(-50%) scale(1);}

/* 笔记本 */
.visual-notebook{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%) scale(0) rotate(-6deg);
  width:120px;height:155px;
  background:linear-gradient(135deg,rgba(245,240,232,.12),rgba(245,240,232,.04));
  border:1px solid rgba(245,240,232,.1);border-radius:8px;
  opacity:0;transition:all 1.2s cubic-bezier(.34,1.56,.64,1);z-index:3;
  box-shadow:0 0 24px rgba(232,180,76,.2);
}
.visual-notebook::before{
  content:'';position:absolute;top:0;left:12px;width:1px;height:100%;
  background:rgba(217,107,107,.3);
}
.visual-notebook.show{opacity:1;transform:translate(-50%,-50%) scale(1) rotate(0);}

/* 身份卡 */
.visual-card{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%) scale(0);
  width:100px;height:140px;perspective:900px;
  opacity:0;transition:all 1s cubic-bezier(.34,1.56,.64,1);z-index:4;
}
.visual-card.show{opacity:1;transform:translate(-50%,-50%) scale(1);}
.visual-card-inner{
  width:100%;height:100%;position:relative;
  transform-style:preserve-3d;transition:transform .7s ease;cursor:pointer;
}
.visual-card-inner.flipped{transform:rotateY(180deg);}
.visual-card-face{
  position:absolute;width:100%;height:100%;backface-visibility:hidden;
  border-radius:10px;border:1px solid rgba(232,180,76,.2);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.visual-card-front{
  background:linear-gradient(160deg,rgba(11,15,30,.95),rgba(30,25,50,.9));
}
.visual-card-back{
  background:linear-gradient(160deg,rgba(232,180,76,.1),rgba(11,15,30,.95));
  transform:rotateY(180deg);
}

/* NPC噢 */
.visual-npc{
  position:absolute;bottom:20%;left:50%;
  transform:translateX(-50%) translateY(30px) scale(.8);
  opacity:0;transition:all 1.5s cubic-bezier(.23,1,.32,1);z-index:3;
  text-align:center;
}
.visual-npc.show{opacity:1;transform:translateX(-50%) translateY(0) scale(1);}
.npc-body{
  width:60px;height:60px;border-radius:50%;
  background:radial-gradient(circle at 40% 35%,rgba(245,240,232,.15),rgba(11,15,30,.9));
  border:1.5px solid rgba(245,240,232,.1);
  display:flex;align-items:center;justify-content:center;
  font-size:28px;margin:0 auto 8px;
  box-shadow:0 0 20px rgba(245,240,232,.05);
  animation:npcBreathe 3s ease-in-out infinite;
}
@keyframes npcBreathe{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
.npc-name{font-size:10px;color:rgba(245,240,232,.3);letter-spacing:2px;}

/* 碰撞光效 */
.collision-flash{
  position:fixed;top:0;left:0;width:100%;height:100%;
  background:radial-gradient(circle,rgba(232,180,76,.15),transparent 70%);
  opacity:0;z-index:20;pointer-events:none;transition:opacity .3s;
}
.collision-flash.show{opacity:1;}

/* 五行图标 */
.wuxing-row{
  display:flex;gap:16px;justify-content:center;
  margin:16px 0;opacity:0;transition:opacity 1s ease;z-index:3;position:relative;
}
.wuxing-row.show{opacity:1;}
.wx-item{
  text-align:center;padding:12px 8px;border-radius:14px;
  background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);
  min-width:56px;
}
.wx-icon{font-size:22px;margin-bottom:4px;}
.wx-label{font-size:9px;color:rgba(255,255,255,.5);letter-spacing:1px;}
.wx-name{font-size:10px;color:rgba(255,255,255,.7);margin-top:2px;font-weight:600;}

/* 纸条场景 */
.note-paper-big{
  width:100%;max-width:300px;
  background:linear-gradient(135deg,rgba(245,240,232,.9),rgba(235,230,220,.95));
  border-radius:4px;padding:36px 28px;position:relative;
  box-shadow:0 16px 60px rgba(0,0,0,.4),0 0 0 1px rgba(0,0,0,.03);
  opacity:0;transform:scale(.85) translateY(20px);
  transition:all 1s cubic-bezier(.23,1,.32,1);z-index:3;
}
.note-paper-big.show{opacity:1;transform:scale(1) translateY(0);}
.note-paper-big::before{
  content:'';position:absolute;top:0;left:20px;right:20px;height:3px;
  background:linear-gradient(90deg,transparent,rgba(200,192,180,.4),transparent);
}
.note-big-text{
  font-size:15px;color:#4A4540;line-height:2.2;font-style:italic;text-align:center;
}

/* 禁区 */
.restricted-zone{
  position:absolute;bottom:15%;left:50%;transform:translateX(-50%);
  width:160px;height:160px;border-radius:50%;
  border:1px dashed rgba(217,107,107,.2);
  display:flex;align-items:center;justify-content:center;
  opacity:0;transition:opacity 1.5s;z-index:2;
}
.restricted-zone.show{opacity:1;}
.restricted-zone::before{
  content:'';position:absolute;inset:10px;border-radius:50%;
  border:1px dashed rgba(217,107,107,.1);
}
.restricted-icon{font-size:32px;opacity:.3;}

/* ===== 选择场景 ===== */
.choice-area{
  display:flex;flex-direction:column;gap:12px;width:100%;max-width:320px;z-index:3;
  opacity:0;transition:opacity .6s;margin-top:20px;
}
.choice-area.show{opacity:1;}
.choice-btn{
  padding:16px 20px;border-radius:14px;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
  color:rgba(255,255,255,.75);font-size:14px;letter-spacing:1px;
  cursor:pointer;text-align:center;transition:all .2s;
}
.choice-btn:active{
  background:rgba(232,180,76,.1);border-color:rgba(232,180,76,.3);
  color:var(--amber);transform:scale(.97);
}
.choice-btn.selected{
  background:rgba(232,180,76,.12);border-color:rgba(232,180,76,.35);color:var(--amber);
}

/* ===== 章节过渡 ===== */
.chapter-screen{
  position:absolute;inset:0;z-index:30;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--dark);opacity:0;pointer-events:none;
  transition:opacity .8s;
}
.chapter-screen.show{opacity:1;pointer-events:auto;}
.chapter-num{font-size:64px;font-weight:900;color:rgba(232,180,76,.15);letter-spacing:8px;}
.chapter-name{font-size:22px;font-weight:700;color:#F5F0E8;letter-spacing:4px;margin-top:12px;}
.chapter-sub{font-size:11px;color:rgba(255,255,255,.2);letter-spacing:3px;margin-top:8px;}

/* ===== 幕尾钩子 ===== */
.act-hook{
  position:absolute;bottom:18%;left:50%;transform:translateX(-50%);
  width:86vw;max-width:360px;text-align:center;z-index:15;
  opacity:0;transition:opacity 1s ease;
}
.act-hook.show{opacity:1;}
.act-hook-tag{
  display:inline-block;font-size:9px;letter-spacing:3px;
  color:rgba(232,180,76,.8);margin-bottom:10px;
  font-family:"SF Mono","Menlo",monospace;
}
.act-hook-line{
  width:24px;height:1px;background:rgba(232,180,76,.4);
  margin:0 auto 10px;
}
.act-hook-text{
  font-size:13px;color:rgba(255,255,255,.85);line-height:1.9;
  letter-spacing:.5px;font-style:italic;
}
.act-hook-text em{
  color:rgba(232,180,76,.95);font-style:normal;
}

/* ===== 最终幕光效 ===== */
.finale-glow{
  position:absolute;top:30%;left:50%;transform:translate(-50%,-50%);
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(232,180,76,.08) 0%,transparent 70%);
  opacity:0;transition:opacity 2s;z-index:1;pointer-events:none;
}
.finale-glow.show{opacity:1;}
</style>
</head>
<body>
<div id="app">
  <div class="starfield" id="starfield"></div>
  <div class="collision-flash" id="collisionFlash"></div>

  <!-- 全部10幕场景 -->
  <div class="scene" id="sc-prologue"></div>
  <div class="scene" id="sc-01"></div>
  <div class="scene" id="sc-02"></div>
  <div class="scene" id="sc-03"></div>
  <div class="scene" id="sc-04"></div>
  <div class="scene" id="sc-05"></div>
  <div class="scene" id="sc-06"></div>
  <div class="scene" id="sc-07"></div>
  <div class="scene" id="sc-08"></div>
  <div class="scene" id="sc-09"></div>
  <div class="scene" id="sc-10"></div>
  <div class="scene" id="sc-easter"></div>

  <!-- 章节过渡屏 -->
  <div class="chapter-screen" id="chapterScreen">
    <div class="chapter-num" id="chNum"></div>
    <div class="chapter-name" id="chName"></div>
    <div class="chapter-sub" id="chSub"></div>
  </div>

  <div class="act-title" id="actTitle"></div>
  <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
</div>

<script>
/* ===== 星空 ===== */
(function(){
  var el=document.getElementById('starfield');
  for(var i=0;i<100;i++){
    var s=document.createElement('div');
    s.className='star';
    var maxO=(.2+Math.random()*.5).toFixed(2);
    s.style.cssText='left:'+(Math.random()*100)+'%;top:'+(Math.random()*100)+'%;width:'+(0.4+Math.random()*1.6)+'px;height:'+(0.4+Math.random()*1.6)+'px;--d:'+(2+Math.random()*5)+'s;--o:'+maxO+';animation-delay:'+(Math.random()*4)+'s;';
    el.appendChild(s);
  }
})();

/* ===== 音效 ===== */
var audioCtx=null;
function ensureAudio(){try{if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state==='suspended')audioCtx.resume();}catch(e){}}
function playTone(freq,dur,type,vol){
  try{
    if(!audioCtx)return;var now=audioCtx.currentTime;
    var o=audioCtx.createOscillator();var g=audioCtx.createGain();
    o.type=type||'triangle';o.frequency.setValueAtTime(freq,now);
    g.gain.setValueAtTime(vol||.04,now);
    g.gain.exponentialRampToValueAtTime(.001,now+(dur||.1));
    o.connect(g);g.connect(audioCtx.destination);
    o.start(now);o.stop(now+(dur||.1));
  }catch(e){}
}

/* ===== 打字机 ===== */
function typewriter(text,el,speed){
  return new Promise(function(resolve){
    el.textContent='';el.classList.remove('done');
    var i=0;
    function tick(){
      if(i<text.length){
        el.textContent+=text.charAt(i);i++;
        if(i%3===0)playTone(500+Math.random()*300,.03,'triangle',.02);
        setTimeout(tick,speed||90);
      }else{el.classList.add('done');resolve();}
    }
    tick();
  });
}

/* ===== 消息添加 ===== */
function addLine(label,text,isUser){
  return new Promise(function(resolve){
    var area=document.querySelector('.scene.active .dialogue-area');
    if(!area){
      area=document.createElement('div');
      area.className='dialogue-area';
      document.querySelector('.scene.active').appendChild(area);
    }
    var line=document.createElement('div');
    line.className='dia-line';
    if(label){
      var lbl=document.createElement('div');
      lbl.className='dia-label';
      lbl.textContent=label;
      line.appendChild(lbl);
    }
    var txt=document.createElement('div');
    txt.className='dia-text'+(isUser?' user':'');
    line.appendChild(txt);
    area.appendChild(line);
    area.scrollTop=area.scrollHeight;
    typewriter(text,txt,85).then(function(){
      setTimeout(resolve,Math.max(text.length*85+800,1800));
    });
  });
}

/* ===== 场景切换 ===== */
function switchScene(id,duration){
  return new Promise(function(resolve){
    document.querySelectorAll('.scene').forEach(function(s){s.classList.remove('active');});
    var target=document.getElementById(id);
    if(target)target.classList.add('active');
    setTimeout(resolve,duration||1200);
  });
}

/* ===== 章节过渡 ===== */
function showChapter(num,name,sub){
  return new Promise(function(resolve){
    var cs=document.getElementById('chapterScreen');
    document.getElementById('chNum').textContent=num;
    document.getElementById('chName').textContent=name;
    document.getElementById('chSub').textContent=sub||'';
    cs.classList.add('show');
    setTimeout(function(){cs.classList.remove('show');setTimeout(resolve,600);},2200);
  });
}

/* ===== 进度 ===== */
function setProgress(pct){document.getElementById('progressFill').style.width=pct+'%';}
function setActTitle(t){
  var el=document.getElementById('actTitle');
  el.textContent=t;el.classList.add('show');
}

/* ===== 碰撞闪光 ===== */
function flashCollision(){
  var el=document.getElementById('collisionFlash');
  el.classList.add('show');playTone(200,1.2,'sine',.08);
  setTimeout(function(){el.classList.remove('show');},800);
}

/* ===== 视觉元素工厂 ===== */
function addPlanet(sceneId){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var p=document.createElement('div');p.className='visual-planet';
    sc.appendChild(p);
    setTimeout(function(){p.classList.add('show');setTimeout(resolve,2200);},100);
  });
}
function addNotebook(sceneId){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var n=document.createElement('div');n.className='visual-notebook';
    sc.appendChild(n);
    setTimeout(function(){n.classList.add('show');playTone(800,.15,'sine',.05);setTimeout(resolve,1200);},100);
  });
}
function addCard(sceneId){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var c=document.createElement('div');c.className='visual-card';
    c.innerHTML='<div class="visual-card-inner"><div class="visual-card-face visual-card-front"><div style="font-size:10px;color:rgba(232,180,76,.5);letter-spacing:2px">TOPSPACE</div><div style="font-size:20px;margin-top:8px">🌍</div><div style="font-size:8px;color:rgba(255,255,255,.3);margin-top:8px">你的星球</div></div><div class="visual-card-face visual-card-back"><div style="font-size:9px;color:rgba(232,180,76,.4);letter-spacing:1px">背面</div></div></div>';
    sc.appendChild(c);
    setTimeout(function(){c.classList.add('show');setTimeout(resolve,1000);},100);
  });
}
function addNpc(sceneId){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var n=document.createElement('div');n.className='visual-npc';
    n.innerHTML='<div class="npc-body">🫧</div><div class="npc-name">噢</div>';
    sc.appendChild(n);
    setTimeout(function(){n.classList.add('show');setTimeout(resolve,1500);},100);
  });
}

/* ===== 选择交互 ===== */
function showChoices(sceneId,items){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var ca=document.createElement('div');ca.className='choice-area';
    items.forEach(function(item){
      var btn=document.createElement('div');
      btn.className='choice-btn';
      btn.textContent=item;
      btn.addEventListener('click',function(){
        document.querySelectorAll('.choice-btn').forEach(function(b){b.classList.remove('selected');});
        btn.classList.add('selected');
        setTimeout(function(){resolve(item);},600);
      });
      ca.appendChild(btn);
    });
    sc.appendChild(ca);
    setTimeout(function(){ca.classList.add('show');},100);
  });
}

/* ===== 触摸提示 ===== */
function showHint(text){
  return new Promise(function(resolve){
    var sc=document.querySelector('.scene.active');
    var h=document.createElement('div');h.className='touch-hint';
    h.innerHTML='<div class="touch-hint-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.3)" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12l3 3 5-6"/></svg></div><div class="touch-hint-text">'+text+'</div>';
    sc.appendChild(h);
    setTimeout(function(){h.classList.add('show');},100);
    // 点击任意处继续
    function done(){
      h.remove();resolve();
    }
    document.addEventListener('click',done,{once:true});
    document.addEventListener('touchstart',done,{once:true});
  });
}

/* ===== 坠落粒子 ===== */
function fallParticles(){
  return new Promise(function(resolve){
    var sc=document.getElementById('sc-01');
    for(var i=0;i<8;i++){
      (function(idx){
        var p=document.createElement('div');p.className='fall-particle';
        p.style.left=(30+Math.random()*40)+'%';
        p.style.top='-10px';
        sc.appendChild(p);
        setTimeout(function(){
          p.style.transition='all '+(1.5+Math.random())+'s cubic-bezier(.23,1,.32,1)';
          p.style.top=(50+Math.random()*30)+'%';
          p.style.opacity='1';
          setTimeout(function(){p.style.opacity='0';},1000);
        },idx*200);
      })(i);
    }
    playTone(400,2,'sine',.06);
    setTimeout(resolve,3500);
  });
}

/* ===== 五行展示 ===== */
function showWuxing(){
  return new Promise(function(resolve){
    var sc=document.getElementById('sc-06');
    var row=document.createElement('div');row.className='wuxing-row';
    var items=[
      {icon:'🔥',label:'火',name:'聚集力',color:'var(--fire)'},
      {icon:'💧',label:'水',name:'渗透力',color:'var(--water)'},
      {icon:'🌱',label:'木',name:'生长力',color:'var(--wood)'},
      {icon:'⚙️',label:'金',name:'打磨力',color:'var(--gold)'},
      {icon:'🌍',label:'土',name:'承载力',color:'var(--earth)'}
    ];
    items.forEach(function(it){
      var d=document.createElement('div');d.className='wx-item';
      d.style.borderColor=it.color.replace('var(','').replace(')','')==='fire'?'rgba(217,107,107,.2)':'rgba(255,255,255,.06)';
      d.innerHTML='<div class="wx-icon">'+it.icon+'</div><div class="wx-label">'+it.label+'</div><div class="wx-name" style="color:'+it.color+'">'+it.name+'</div>';
      row.appendChild(d);
    });
    sc.appendChild(row);
    setTimeout(function(){row.classList.add('show');setTimeout(resolve,1500);},100);
  });
}

/* ===== 纸条展示 ===== */
function showNote(sceneId){
  return new Promise(function(resolve){
    var sc=document.getElementById(sceneId);
    var n=document.createElement('div');n.className='note-paper-big';
    n.innerHTML='<div class="note-big-text">因为有一个人消失了，<br>我决定把那些没说的话，<br>说给所有人听。</div>';
    sc.appendChild(n);
    setTimeout(function(){n.classList.add('show');playTone(300,.8,'sine',.06);setTimeout(resolve,2000);},100);
  });
}

/* ===== 禁区展示 ===== */
function showRestricted(){
  return new Promise(function(resolve){
    var sc=document.getElementById('sc-08');
    var rz=document.createElement('div');rz.className='restricted-zone';
    rz.innerHTML='<div class="restricted-icon">⚠️</div>';
    sc.appendChild(rz);
    setTimeout(function(){rz.classList.add('show');setTimeout(resolve,2000);},100);
  });
}

/* ===== 章节流程编排 ===== */
var chapters = [
  /* ===== 序章 ===== */
  function(){
    return showChapter('00','序 章','Prologue').then(function(){
      setActTitle('拓圈宇宙 · 觉醒纪元');
      return addLine('SYSTEM','欢迎来到新宇宙。');
    }).then(function(){
      return addLine('SYSTEM','这不是一个游戏。\n也不是一个社交软件。');
    }).then(function(){
      return addLine('SYSTEM','这是一个……\n正在被书写的宇宙。\n而书写者，是你。');
    }).then(function(){
      return showHint('点击继续');
    });
  },

  /* ===== 第1幕·坠落 ===== */
  function(){
    return showChapter('01','坠 落','Fall').then(function(){
      setActTitle('第一幕 · 坠落');
      return fallParticles();
    }).then(function(){
      return addLine('SYSTEM','你感觉到了吗？\n有一束光，正在降落。');
    }).then(function(){
      return addLine('SYSTEM','旧宇宙熄灭了。\n不是毁灭——是安静地消失。');
    }).then(function(){
      return addLine('SYSTEM','所有星球的光同时熄灭。\n没有人尖叫，没有人挣扎。\n因为没有人注意到。');
    }).then(function(){
      return addLine('SYSTEM','它们被喂养得太饱了。\n饱到忘记了——自己曾经也会发光。');
    }).then(function(){
      return addLine(null,'你确定，你是第一次来这里吗？',true);
    }).then(function(){
      return showHook('sc-01','第一幕完',['什么叫"等着"？','那行字为什么自己删掉了？']);
    }).then(function(){
      return showHint('点击继续');
    });
  },

  /* ===== 第2幕·三件东西 ===== */
  function(){
    return showChapter('02','三件东西','Three Gifts').then(function(){
      setActTitle('第二幕 · 三件东西');
      return addPlanet('sc-02');
    }).then(function(){
      return addLine('SYSTEM','既然来了，总不能空手。\n我先送你三样东西。');
    }).then(function(){
      return addLine('SYSTEM','第一件，一颗星球。\n只有一颗，你要好好珍惜它。');
    }).then(function(){
      return addLine(null,'星球？这玩意儿能干什么？',true);
    }).then(function(){
      return addLine('SYSTEM','现在干不了什么。\n但以后，它会跟着你一起长大。');
    }).then(function(){
      return addNotebook('sc-02');
    }).then(function(){
      return addLine('SYSTEM','第二件，一本笔记本。');
    }).then(function(){
      return addLine(null,'笔记本？就这？',true);
    }).then(function(){
      return addLine('SYSTEM','你在这里写的每一个字，\n都会成为你的一部分。');
    }).then(function(){
      return addLine('SYSTEM','你以为你只是在"记录"。\n但其实，你是在往这个宇宙里……\n写入你的灵魂。');
    }).then(function(){
